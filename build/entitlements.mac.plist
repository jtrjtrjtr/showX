<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron's JIT compilation -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Required for Electron's unsigned executable memory -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Required for Electron to load plugins (e.g. native node modules) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Network access for LAN communication and mDNS -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- Keychain access for SecretStore (token storage) -->
  <key>keychain-access-groups</key>
  <array>
    <string>$(AppIdentifierPrefix)cz.xlab.showx</string>
  </array>
</dict>
</plist>
