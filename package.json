{
  "name": "showx-workspace",
  "version": "0.1.6",
  "private": true,
  "description": "ShowX \u2014 XLAB master FOH product (LAN-first Electron + modular shell). Absorbs BridgeX 0.3.x.",
  "workspaces": [
    "src/main",
    "src/modules/*",
    "src/shared",
    "pwa"
  ],
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:parity": "vitest run tests/parity",
    "lint": "eslint src pwa",
    "dev": "concurrently 'pnpm --filter showx-pwa dev' 'pnpm --filter showx-main dev'",
    "dev:electron": "pnpm --filter showx-main dev",
    "dev:pwa": "pnpm --filter showx-pwa dev",
    "build": "pnpm -r build",
    "build:main": "pnpm --filter showx-main build",
    "build:pwa": "pnpm --filter showx-pwa build",
    "clean": "rimraf src/main/dist pwa/dist dist-electron",
    "dist": "electron-builder --config electron-builder.yml",
    "dashboard": "python3 scripts/render_dashboard.py"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "express": "^4.18.2",
    "fake-indexeddb": "^5.0.2",
    "jsdom": "^24.0.0",
    "lib0": "^0.2.88",
    "playwright": "^1.42.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.3",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "ws": "^8.16.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.10",
    "zod": "^3.22.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "src/main/dist/index.js",
  "dependencies": {
    "@julusian/midi": "^3.5.0",
    "bonjour-service": "^1.2.1",
    "cors": "^2.8.5",
    "dmxnet": "^0.9.0",
    "e131": "^1.1.2",
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6",
    "keytar": "^7.9.0",
    "lib0": "^0.2.88",
    "osc-min": "^1.1.2",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.3",
    "uuid": "^10.0.0",
    "ws": "^8.16.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.10",
    "zod": "^3.22.0"
  }
}
